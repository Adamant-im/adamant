{
  "name": "adamant",
  "version": "0.9.0",
  "description": "ADAMANT Blockchain Node",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "node app.js",
    "start:testnet": "node app.js --config test/config.json --genesis test/genesisBlock.json",
    "start:localnet": "node scripts/localnet/start.js",
    "stop:localnet": "node scripts/localnet/stop.js",
    "status:localnet": "node scripts/localnet/status.js",
    "drop:localnet": "node scripts/localnet/drop.js",
    "scenario:testnet": "node scripts/live-test/testnet.js",
    "scenario:localnet": "node scripts/live-test/localnet.js",
    "test:full": "npx grunt test --verbose",
    "test:single": "npx mocha --trace-uncaught",
    "test:unit": "npx mocha test/unit/* --trace-uncaught",
    "test:unit:fast": "npx mocha test/unit/* --exclude test/unit/logic/blockReward.js --exclude test/unit/sql/blockRewards.js --trace-uncaught",
    "test:api": "npx mocha test/api/* --trace-uncaught",
    "test:fast": "npx mocha --exclude test/unit/sql/blockRewards.js --exclude test/api/delegates.js --exclude test/api/peer.transactions.stress.js --exclude test/api/peer.transactions.votes.js test/unit/**/* test/api/**/*",
    "eslint": "npx grunt eslint-nofix --verbose",
    "eslint:file": "npx eslint -f codeframe",
    "eslint:fix": "npx eslint -f codeframe --fix",
    "eslint:fixrule": "npx eslint -f codeframe --no-config-lookup --fix --rule"
  },
  "keywords": [
    "adm",
    "adamant",
    "blockchain",
    "messenger",
    "messaging",
    "decentralization",
    "anonymity",
    "tor",
    "privacy",
    "security",
    "encryption",
    "crypto",
    "cryptocurrency",
    "dpos"
  ],
  "author": "ADAMANT Foundation <devs@adamant.im>, ADAMANT Tech Labs <devs@adamant.im>, Lisk Foundation <admin@lisk.io>, lightcurve GmbH <admin@lightcurve.io>",
  "license": "GPL-3.0",
  "dependencies": {
    "async": "=3.2.6",
    "axios": "^1.17.0",
    "bignumber.js": "=11.1.3",
    "bitcore-mnemonic": "=10.10.7",
    "body-parser": "=2.2.2",
    "bytebuffer": "=5.0.1",
    "change-case": "^5.4.4",
    "colors": "=1.4.0",
    "commander": "=15.0.0",
    "compression": "=1.8.1",
    "cors": "=2.8.6",
    "ejs": "=6.0.1",
    "execa": "^9.6.1",
    "express": "=5.2.1",
    "express-domain-middleware": "=0.1.0",
    "express-rate-limit": "=8.5.2",
    "express-slow-down": "3.1.0",
    "extend": "=3.0.2",
    "js-nacl": "^1.4.0",
    "json-schema": "=0.4.0",
    "knex": "^3.2.10",
    "lodash": "=4.18.1",
    "method-override": "=3.0.0",
    "neoip": "^3.1.0",
    "npm": "=11.17.0",
    "pg-monitor": "=3.1.0",
    "pg-native": "=3.8.0",
    "pg-promise": "=12.6.2",
    "randomstring": "=1.3.1",
    "redis": "=6.0.0",
    "rimraf": "=6.1.3",
    "semver": "=7.8.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sodium-native": "5.1.0",
    "strftime": "=0.10.3",
    "unzipper": "^0.12.3",
    "valid-url": "=1.0.9",
    "validator.js": "=2.0.4",
    "z-schema": "=12.3.1"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "chai-bignumber": "^3.1.0",
    "eslint-config-google": "^0.14.0",
    "eslint-formatter-codeframe": "^7.32.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "grunt": "^1.6.2",
    "grunt-cli": "^1.5.0",
    "grunt-contrib-compress": "^2.0.0",
    "grunt-contrib-obfuscator": "^8.0.0",
    "grunt-eslint": "^26.0.0",
    "grunt-exec": "^3.0.0",
    "globals": "^17.6.0",
    "mocha": "^11.7.6",
    "moment": "^2.30.1",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "bn.js": "4.12.3",
    "grunt-contrib-obfuscator": {
      "javascript-obfuscator": "^4.0.0"
    },
    "serialize-javascript": "7.0.5"
  },
  "config": {
    "minVersion": ">=0.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adamant-im/adamant.git"
  },
  "bugs": {
    "url": "https://github.com/Adamant-im/adamant/issues"
  },
  "homepage": "https://github.com/Adamant-im/adamant#readme"
}
